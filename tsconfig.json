{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/config.ts",
    "src/zalo/client.ts",
    "src/zalo/types.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
