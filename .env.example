PORT=3000

# Firebase UID của giáo viên — dùng làm API key bảo vệ Zalo endpoints
API_KEY=your_firebase_uid_here

# Firebase config (inject vào dashboard HTML)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=yourapp.firebaseapp.com
FIREBASE_DATABASE_URL=https://yourapp-default-rtdb.asia-southeast1.firebasedatabase.app

# (Tùy chọn) Credentials Zalo dạng base64 — dùng để khôi phục session sau khi restart
# Sau khi đăng nhập QR lần đầu, gọi GET /credentials (header x-api-key) để lấy giá trị này
# ZALO_CREDENTIALS=eyJpbWVpIjoiLi4uIn0=

# (Tùy chọn) Đường dẫn file credentials (mặc định: credentials.json)
# ZALO_CREDENTIALS_PATH=./credentials.json
